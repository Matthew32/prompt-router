{
  "name": "prompt-router",
  "version": "0.1.0",
  "description": "Classify a prompt and recommend which Claude model, effort level, and agentic strategy to use — with a Monaco-based editor.",
  "type": "module",
  "main": "electron/main.mjs",
  "bin": {
    "prompt-router": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "serve": "tsx src/server.ts",
    "serve:build": "node dist/server.js",
    "app": "npm run build && electron .",
    "rebuild:electron": "electron-rebuild -f -w node-pty",
    "rebuild:node": "npm rebuild node-pty",
    "dist:app": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "express": "^4.21.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.12",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "@electron/rebuild": "^3.7.0"
  },
  "build": {
    "appId": "com.playlogiq.promptrouter",
    "productName": "prompt-router",
    "directories": { "output": "release" },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": { "target": ["dmg", "zip"], "category": "public.app-category.developer-tools" },
    "win": { "target": ["nsis"] },
    "linux": { "target": ["AppImage"], "category": "Development" }
  }
}
